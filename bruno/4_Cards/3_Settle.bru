meta {
  name: Settle All Captured Purchases
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/cards/settle
}

body:json {
  {}
}

script:post-response {
  if (res.body.status === "settled") {
    console.log("Settled", res.body.settled_transactions, "transaction(s)");
    console.log("Net amount:", res.body.net_amount);
  } else {
    console.log("Nothing to settle");
  }
}
